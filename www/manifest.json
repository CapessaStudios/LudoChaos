      "icons": [
        {
          "src": "assets/imagem/logo192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Online",
      "short_name": "Online",
      "description": "Modo multiplayer",
      "url": "./index.html#online",
      "icons": [
        {
          "src": "assets/imagem/logo192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
