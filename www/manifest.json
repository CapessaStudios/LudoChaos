{
  "id": "/LudoChaos",

  "name": "LudoChaos",
  "short_name": "LudoChaos",
  "description": "LudoChaos é um jogo moderno de Ludo com cartas estratégicas, poderes únicos, multiplayer online e offline desenvolvido pela Capessa Studios.",

  "lang": "pt",
  "dir": "ltr",

  "start_url": "./index.html",
  "scope": "./",

  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],

  "orientation": "portrait-primary",

  "background_color": "#120F0E",
  "theme_color": "#1A1F2E",

  "categories": [
    "games",
    "strategy",
    "board"
  ],

  "prefer_related_applications": false,

  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],

  "icons": [
    {
      "src": "assets/imagem/logo192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "assets/imagem/logo512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  "screenshots": [
    {
      "src": "assets/imagem/screen1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tela inicial"
    },
    {
      "src": "assets/imagem/screen2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Menu principal"
    },
    {
      "src": "assets/imagem/screen3.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tabuleiro e cartas"
    }
  ],

  "shortcuts": [
    {
      "name": "Jogar",
      "short_name": "Jogar",
      "description": "Iniciar partida",
